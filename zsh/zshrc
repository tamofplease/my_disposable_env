# Homebrew (arm64: /opt/homebrew, Intel: /usr/local)
if [ -x /opt/homebrew/bin/brew ]; then
  eval "$(/opt/homebrew/bin/brew shellenv)"
elif [ -x /usr/local/bin/brew ]; then
  eval "$(/usr/local/bin/brew shellenv)"
fi

# completion
fpath=(~/.zsh/completion $fpath)
autoload -Uz compinit
compinit -u

export CLICOLOR=1

# locally-installed tools (claude code, uv-managed tools, etc.)
export PATH="$HOME/.local/bin:$PATH"

# volta (node / pnpm / typescript)
export VOLTA_HOME="$HOME/.volta"
export PATH="$VOLTA_HOME/bin:$PATH"
export VOLTA_FEATURE_PNPM=1

# rust (rustup)
[ -f "$HOME/.cargo/env" ] && . "$HOME/.cargo/env"

# gcloud (installed non-interactively to ~/google-cloud-sdk)
[ -f "$HOME/google-cloud-sdk/path.zsh.inc" ] && . "$HOME/google-cloud-sdk/path.zsh.inc"
[ -f "$HOME/google-cloud-sdk/completion.zsh.inc" ] && . "$HOME/google-cloud-sdk/completion.zsh.inc"

# prompt (starship)
command -v starship >/dev/null 2>&1 && eval "$(starship init zsh)"

# ghq + fzf: jump to any cloned repo with Ctrl-]
if command -v ghq >/dev/null 2>&1 && command -v fzf >/dev/null 2>&1; then
  function _ghq_fzf_widget() {
    local dir
    dir=$(ghq list | fzf) || return
    BUFFER="cd $(ghq root)/${dir}"
    zle accept-line
  }
  zle -N _ghq_fzf_widget
  bindkey '^]' _ghq_fzf_widget
fi
